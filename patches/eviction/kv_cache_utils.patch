+    def pop_scored_n(self, n: int, policy: str, now: float = 0.0, lam: float = 0.1):
+        """Select and remove n free blocks using the given eviction policy.
+
+        policy="tdf"  Time-Decayed Frequency:
+            Score(b) = (hit_count+1) * exp(-lam * (now - last_alloc_time))
+
+        policy="cf"   Cascaded Frequency:
+            Score(b) = (hit_count+1) / (prefix_depth+1)
+            Shallow prefix blocks (depth 0) are preserved over deep tail blocks
+            because evicting a shallow block invalidates all blocks chained after it.
+
+        Lower score => evict first.
+        """
+        if n == 0:
+            return []
+        assert self.num_free_blocks >= n
+
+        # Collect all free blocks with scores.
+        candidates = []
+        curr = self.fake_free_list_head.next_free_block
+        pos = 0
+        while curr is not None and curr.next_free_block is not None:
+            if policy == "cf":
+                score = (curr.hit_count + 1) / (curr.prefix_depth + 1)
+            else:  # tdf
+                age = now - curr.last_alloc_time
+                score = (curr.hit_count + 1) * math.exp(-lam * age)
+            candidates.append((score, pos, curr))
+            curr = curr.next_free_block
+            pos += 1
+
+        # Sort ascending: lowest score evicted first; pos breaks ties.
+        candidates.sort(key=lambda x: (x[0], x[1]))
+        selected = [blk for _, _, blk in candidates[:n]]
+
+        # Remove selected blocks from the doubly-linked list.
+        for block in selected:
+            block.prev_free_block.next_free_block = block.next_free_block
+            block.next_free_block.prev_free_block = block.prev_free_block
+            block.prev_free_block = None
+            block.next_free_block = None
+
+        self.num_free_blocks -= n
+        return selected
+
